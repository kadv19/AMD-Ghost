<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ghost_bg_main"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/ghost_bg_deep"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Ghost Avatar with glow ring -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp">
                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/ghost_avatar_ring"/>
                <!-- You can replace this with an actual ghost icon later -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_help"
                    app:tint="@color/ghost_accent"/>
            </FrameLayout>

            <!-- Title and subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Ghost"
                    android:textColor="@color/ghost_text_main"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your memories, always with you"
                    android:textColor="@color/ghost_text_dim"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Status pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ghost_input_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/ghost_avatar_ring"/>

                <TextView
                    android:id="@+id/textViewStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="On-Device"
                    android:textColor="@color/ghost_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Chat RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/inputBarContainer"/>

    <!-- Thinking indicator positioned above input -->
    <LinearLayout
        android:id="@+id/thinkingLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/ghost_ai_bubble"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputBarContainer"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/thinkingDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●  ●  ●"
            android:textColor="@color/ghost_accent"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Input Bar Container -->
    <LinearLayout
        android:id="@+id/inputBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/ghost_bg_deep"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/buttonToggleMode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/ghost_input_bg"
            android:src="@android:drawable/ic_menu_help"
            app:tint="@color/ghost_accent"
            android:contentDescription="Toggle Mode"/>

        <EditText
            android:id="@+id/editTextPrompt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/ghost_input_bg"
            android:hint="Ask your ghost..."
            android:inputType="textMultiLine|textCapSentences"
            android:importantForAutofill="no"
            android:maxLines="4"
            android:minHeight="50dp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:textColor="@color/ghost_text_main"
            android:textColorHint="@color/ghost_text_dim"
            android:textSize="15sp"/>

        <ImageButton
            android:id="@+id/buttonSend"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/ghost_button_send"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/black"
            android:enabled="false"
            android:contentDescription="Send"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
