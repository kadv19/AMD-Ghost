<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF7"
    android:padding="32dp">

    <!-- Ghost Icon -->
    <ImageView
        android:id="@+id/ghostIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ghost_avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Awaken Your Ghost"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/ghostIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter the identity from your old phone"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Username Label -->
    <TextView
        android:id="@+id/labelUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ghost ID (your username)"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#7C3AED"
        android:letterSpacing="0.05"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Username Input -->
    <EditText
        android:id="@+id/editUsername"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="e.g. Advaith Kashyap"
        android:textSize="16sp"
        android:textColor="#1A1A2E"
        android:textColorHint="#9CA3AF"
        android:background="@drawable/bg_input_field"
        android:inputType="textPersonName"
        android:importantForAutofill="no"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ghost Key Label -->
    <TextView
        android:id="@+id/labelGhostKey"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ghost Key (from your old phone)"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#7C3AED"
        android:letterSpacing="0.05"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/editUsername"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Ghost Key Input -->
    <EditText
        android:id="@+id/editGhostKey"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="e.g. alpha-bravo-ghost-delta"
        android:textSize="16sp"
        android:textColor="#1A1A2E"
        android:textColorHint="#9CA3AF"
        android:background="@drawable/bg_input_field"
        android:inputType="text"
        android:importantForAutofill="no"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelGhostKey"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Error Text -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#EF4444"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/editGhostKey"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#7C3AED"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvError"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#7C3AED"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Unlock Button -->
    <Button
        android:id="@+id/btnUnlock"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="AWAKEN GHOST"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:backgroundTint="#7C3AED"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Helper text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Place brain.json in:\nAndroid/data/com.example.mediapipeapp/files/"
        android:textSize="11sp"
        android:textColor="#9CA3AF"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnUnlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>