<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MediaPipeApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="android:windowBackground">@color/background_warm</item>
        <item name="android:statusBarColor">@color/background_warm</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/background_warm</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">true</item>
    </style>

    <style name="Theme.MediaPipeApp" parent="Base.Theme.MediaPipeApp" />
</resources>